<group name="syscheck, custom_fim, webshell_detection">
  <rule id="100050" level="12">
    <if_sid>554</if_sid>
    <match>.php</match>
    <regex>/var/www/html/|/usr/share/nginx/html/</regex>
    <description>CRITICAL: Potential Web Shell Dropped! A PHP file was created or modified in a public web directory.</description>
    <mitre>
      <id>T1505.003</id> </mitre>
    <group>web_attack, persistence,</group>
  </rule>
</group>
